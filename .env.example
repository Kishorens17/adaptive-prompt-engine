# ── LLM Provider API Keys ─────────────────────────────────────────────────
# Copy this file to .env and fill in your real keys.
# NEVER commit .env to version control.

GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
# ── Smart Model Routing (optional overrides) ──────────────────────────────
# Uncomment and change to override the default model per tier.
# ROUTER_LOW_MODEL_GEMINI=gemini-2.0-flash-lite
# ROUTER_MEDIUM_MODEL_GEMINI=gemini-2.5-flash
# ROUTER_HIGH_MODEL_GEMINI=gemini-2.5-pro
# ROUTER_LOW_MODEL_OPENAI=gpt-4o-mini
# ROUTER_HIGH_MODEL_OPENAI=gpt-4o
# ROUTER_LOW_MODEL_GROQ=llama-3.3-70b-versatile
# ROUTER_HIGH_MODEL_GROQ=llama-3.3-70b-versatile

# ── Semantic Cache ────────────────────────────────────────────────────────
# CACHE_SIMILARITY_THRESHOLD=0.92

# ── Session Memory ────────────────────────────────────────────────────────
# SESSION_TTL_HOURS=24

# ── LLM Judge ─────────────────────────────────────────────────────────────
# LLM_JUDGE_ENABLED=true
