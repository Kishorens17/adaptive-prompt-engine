# ── LLM Provider API Keys ─────────────────────────────────────────────────
# Copy this file to .env and fill in your real keys.
# NEVER commit .env to version control.

GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# ── Smart Model Routing (optional overrides) ──────────────────────────────
# Uncomment and change to override the default model per tier.
# ROUTER_LOW_MODEL_GEMINI=gemini-2.0-flash-lite
# ROUTER_MEDIUM_MODEL_GEMINI=gemini-2.5-flash
# ROUTER_HIGH_MODEL_GEMINI=gemini-2.5-pro

# ── Semantic Cache ────────────────────────────────────────────────────────
# Cosine similarity threshold for cache hits (0.0–1.0). Higher = stricter.
# Default: 0.92
# CACHE_SIMILARITY_THRESHOLD=0.92
